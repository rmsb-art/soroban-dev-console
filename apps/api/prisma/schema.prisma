generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A mutable developer workspace that can later be shared as a read-only snapshot.
model Workspace {
  id                String              @id @default(cuid())
  ownerKey          String              @map("owner_key")
  name              String
  description       String?
  selectedNetwork   String              @default("testnet") @map("selected_network")
  /// BE-006: Monotonically increasing revision counter for optimistic concurrency control.
  revision          Int                 @default(0)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  savedContracts    SavedContract[]
  savedInteractions SavedInteraction[]
  artifacts         WorkspaceArtifact[]
  shares            ShareLink[]

  @@index([ownerKey])
  @@index([updatedAt])
  @@map("workspaces")
}

model SavedContract {
  id          String     @id @default(cuid())
  workspaceId String     @map("workspace_id")
  contractId  String     @map("contract_id")
  network     String
  label       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contractId, network])
  @@map("saved_contracts")
}

model SavedInteraction {
  id            String     @id @default(cuid())
  workspaceId   String     @map("workspace_id")
  contractId    String?    @map("contract_id")
  functionName  String     @map("function_name")
  name          String?
  network       String
  argumentsJson Json       @map("arguments_json")
  createdAt     DateTime   @default(now()) @map("created_at")
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([contractId, network])
  @@index([functionName, network])
  @@map("saved_interactions")
}

/// File and derived metadata captured inside a workspace, including WASM uploads.
model WorkspaceArtifact {
  id          String     @id @default(cuid())
  workspaceId String     @map("workspace_id")
  kind        String
  name        String
  network     String?
  hash        String?
  metadata    Json?
  createdAt   DateTime   @default(now()) @map("created_at")
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, kind])
  @@index([hash])
  @@map("workspace_artifacts")
}

/// BE-011: Durable audit record for workspace and share mutations.
model AuditLog {
  id          String   @id @default(cuid())
  actor       String
  action      String
  resourceType String  @map("resource_type")
  resourceId  String   @map("resource_id")
  summary     String?
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actor])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// BE-215: Support ticket with category tagging and routing metadata for Wave 5 triage.
model SupportTicket {
  id          String   @id @default(cuid())
  subject     String
  body        String
  category    String   /// verification | payout | appeal | bug | abuse
  status      String   @default("open") /// open | in_progress | resolved | closed
  priority    String   @default("normal") /// low | normal | high | urgent
  reporterKey String   @map("reporter_key")
  assigneeKey String?  @map("assignee_key")
  tags        String   @default("[]") /// JSON-encoded string[]
  metadata    Json?
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category, status])
  @@index([reporterKey])
  @@index([status, priority])
  @@index([createdAt])
  @@map("support_tickets")
}

/// Immutable, read-only links that capture a point-in-time workspace snapshot.
model ShareLink {
  id            String     @id @default(cuid())
  workspaceId    String     @map("workspace_id")
  token         String     @unique
  label         String?
  snapshotJson  Json       @map("snapshot_json")
  expiresAt     DateTime?  @map("expires_at")
  revokedAt     DateTime?  @map("revoked_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("share_links")
}
