{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    "noEmitOnError": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/index.ts",
    "src/controllers/**/*.ts",
    "src/routes/**/*.ts",
    "src/middleware/**/*.ts",
    "src/services/**/*.ts",
    "src/modules/**/*.test.ts",
    "src/modules/**/*.spec.ts"
  ]
}
